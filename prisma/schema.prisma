generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NEXTAUTH TABLES
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model OtpVerification {
  id        String   @id @default(cuid())
  phone     String   @unique
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model User {
  id             String          @id @default(cuid())
  clerkId        String?         @unique
  name           String?
  email          String          @unique
  emailVerified  DateTime?
  image          String?
  phone          String?
  role           Role            @default(USER)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  password       String?
  consentSignedAt DateTime?
  
  accounts       Account[]
  sessions       Session[]
  bookings       Booking[]
  intents        BookingIntent[]
  gyms           Gym[]           @relation("GymOwner")
  reviews        Review[]
  supportTickets SupportTicket[]
  transactions   Transaction[]
  fcmToken       String?
}

model Gym {
  id                  String     @id @default(cuid())
  name                String
  description         String?
  location            String
  latitude            Float?
  longitude           Float?
  imageUrls           String[]
  ownerId             String
  status              GymStatus  @default(PENDING)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  baseCommissionRate  Float      @default(15.0)
  commissionFreeUntil DateTime?
  onboardingFeeAmount Float?
  onboardingFeePaid   Boolean    @default(false)
  bankAccountNumber   String?
  bankIfscCode        String?
  bankProofUrl        String?
  panNumber           String?
  panPhotoUrl         String?
  registrationDocUrl  String?
  avgRating           Float      @default(0)
  openingTime         String?
  closingTime         String?
  weeklyOffDay        String?
  isPaused            Boolean    @default(false)

  owner   User      @relation("GymOwner", fields: [ownerId], references: [id])
  reviews Review[]
  plans   Plan[]
  bookings Booking[]
  intents  BookingIntent[]

  @@index([ownerId])
}

model Plan {
  id          String   @id @default(cuid())
  gymId       String
  name        String?
  price       Float
  description String?
  type        PlanType @default(DAY)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  gym         Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  bookings    Booking[]
  intents     BookingIntent[]

  @@index([gymId])
}

model Booking {
  id              String        @id @default(cuid())
  userId          String
  gymId           String
  planId          String
  totalAmount     Float
  status          BookingStatus @default(BOOKED)
  paymentId       String?
  orderId         String?       @unique
  checkInTime     DateTime?
  completionTime  DateTime?
  rating          Float?
  review          String?
  bookingDate     DateTime?     @default(now())
  otp             String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  invoiceUrl      String?
  members         Int           @default(1)
  selectedAddons  Json?
  qrCode          String?
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  gym  Gym  @relation(fields: [gymId], references: [id])
  plan Plan @relation(fields: [planId], references: [id])

  @@index([userId])
  @@index([gymId])
  @@index([planId])
  @@index([status])
}

model Review {
  id        String   @id @default(cuid())
  gymId     String
  userId    String
  rating    Float
  comment   String?
  createdAt DateTime @default(now())
  gym       Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([gymId])
  @@index([userId])
}

model Transaction {
  id              String   @id @default(cuid())
  userId          String
  amount          Float
  type            String
  status          String
  providerOrderId String?  @unique
  paymentId       String?  @unique
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SupportTicket {
  id        String       @id @default(cuid())
  userId    String
  subject   String
  message   String
  status    TicketStatus @default(OPEN)
  category  TicketCategory
  ticketId  String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum TicketCategory {
  PAYMENT
  BOOKING
  DISPUTE
  FEEDBACK
  TECHNICAL
  OTHER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum Role {
  USER
  GYM_OWNER
  ADMIN
}

enum GymStatus {
  PENDING
  APPROVED
  REJECTED
  AWAITING_PAYMENT
  SUSPENDED
}

enum PaymentType {
  ONLINE
  PAY_AT_GYM
}

enum PlanType {
  DAY
  WEEK
  MONTH
}

enum BookingStatus {
  BOOKED
  CHECKED_IN
  COMPLETED
  CANCELLED
}

model PlatformSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model BookingIntent {
  id             String       @id @default(cuid())
  userId         String
  gymId          String
  planId         String
  totalAmount    Float
  members        Int          @default(1)
  selectedAddons Json?
  status         IntentStatus @default(PENDING)
  qrCode         String?
  otp            String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  gym            Gym          @relation(fields: [gymId], references: [id])
  plan           Plan         @relation(fields: [planId], references: [id])

  @@index([userId])
  @@index([planId])
  @@index([status])
}

enum IntentStatus {
  PENDING
  CONVERTED
  RECOVERED
  ABANDONED
}
