generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model OtpVerification {
  id        String   @id @default(cuid())
  phone     String   @unique
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model User {
  id           String        @id @default(cuid())
  clerkId      String        @unique
  name         String?
  email        String        @unique
  password     String?
  phone        String?
  role         Role          @default(USER)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  bookings     Booking[]
  reviews      Review[]
  gyms         Gym[]         @relation("GymOwner")
  transactions Transaction[]
  supportTickets SupportTicket[]
}

model Gym {
  id                   String     @id @default(cuid())
  name                 String
  description          String?
  location             String
  latitude             Float?
  longitude            Float?
  imageUrls            String[]
  ownerId              String
  status               GymStatus  @default(PENDING)
  onboardingFeeAmount  Float?
  onboardingFeePaid    Boolean    @default(false)
  commissionFreeUntil  DateTime?
  baseCommissionRate   Float      @default(15.0)
  isPaused             Boolean    @default(false)
  
  // KYC & Legal
  panNumber            String?
  panPhotoUrl          String?
  bankAccountNumber    String?
  bankIfscCode         String?
  bankProofUrl         String?
  registrationDocUrl   String?
  moUrl                String?    // Agreement Document

  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  bookings             Booking[]
  reviews              Review[]
  totalRating          Float      @default(0)
  numReviews           Int        @default(0)
  avgRating            Float      @default(0)
  owner                User       @relation("GymOwner", fields: [ownerId], references: [id])
  addons               GymAddon[]
  plans                Plan[]
}

model Review {
  id        String   @id @default(cuid())
  gymId     String
  userId    String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  gym       Gym      @relation(fields: [gymId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Plan {
  id        String    @id @default(cuid())
  gymId     String
  type      PlanType
  price     Float
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  bookings  Booking[]
  gym       Gym       @relation(fields: [gymId], references: [id])
}

model GymAddon {
  id          String   @id @default(cuid())
  gymId       String
  name        String
  price       Float
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  gym         Gym      @relation(fields: [gymId], references: [id])
}

model Booking {
  id             String        @id @default(cuid())
  userId         String
  gymId          String
  planId         String
  bookingDate    DateTime
  status         BookingStatus @default(BOOKED)
  paymentType    PaymentType   @default(ONLINE)
  paymentId      String?
  otp            String?
  qrCode         String?
  voucherPdfUrl  String?
  members        Json?
  selectedAddons Json?
  totalAmount    Float
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  gym            Gym           @relation(fields: [gymId], references: [id])
  plan           Plan          @relation(fields: [planId], references: [id])
  user           User          @relation(fields: [userId], references: [id])
}

model Transaction {
  id                String   @id @default(cuid())
  userId            String
  amount            Float
  status            String
  razorpayOrderId   String   @unique
  razorpayPaymentId String?  @unique
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id])
}

model SupportTicket {
  id        String         @id @default(cuid())
  ticketId  String         @unique // PF-XXXX
  userId    String
  subject   String
  message   String
  category  TicketCategory @default(DISPUTE)
  status    TicketStatus   @default(OPEN)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id])
}

enum TicketCategory {
  DISPUTE
  FEEDBACK
  TECHNICAL
  OTHER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum Role {
  USER
  GYM_OWNER
  ADMIN
}

enum GymStatus {
  PENDING
  AWAITING_PAYMENT
  APPROVED
  REJECTED
  SUSPENDED
}

enum PaymentType {
  ONLINE
  PAY_AT_GYM
}

enum PlanType {
  DAY
  WEEK
  MONTH
}

enum BookingStatus {
  BOOKED
  CHECKED_IN
  COMPLETED
  CANCELLED
}
