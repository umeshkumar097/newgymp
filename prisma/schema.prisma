generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model OtpVerification {
  id        String   @id @default(cuid())
  phone     String   @unique
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model User {
  id             String          @id @default(cuid())
  clerkId        String          @unique
  name           String?
  email          String          @unique
  phone          String?
  role           Role            @default(USER)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  password       String?
  bookings       Booking[]
  intents        BookingIntent[]
  gyms           Gym[]           @relation("GymOwner")
  reviews        Review[]
  supportTickets SupportTicket[]
  transactions   Transaction[]
}

model Gym {
  id                  String     @id @default(cuid())
  name                String
  description         String?
  location            String
  latitude            Float?
  longitude           Float?
  imageUrls           String[]
  ownerId             String
  status              GymStatus  @default(PENDING)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  baseCommissionRate  Float      @default(15.0)
  commissionFreeUntil DateTime?
  onboardingFeeAmount Float?
  onboardingFeePaid   Boolean    @default(false)
  bankAccountNumber   String?
  bankIfscCode        String?
  bankProofUrl        String?
  panNumber           String?
  panPhotoUrl         String?
  registrationDocUrl  String?
  avgRating           Float      @default(0)
  isPaused            Boolean    @default(false)
  openingTime         String?    // e.g. "06:00 AM"
  closingTime         String?    // e.g. "10:00 PM"
  weeklyOffDay        String?    @default("None") // e.g. "Sunday"
  moUrl               String?
  numReviews          Int        @default(0)
  totalRating         Float      @default(0)
  bookings            Booking[]
  intents             BookingIntent[]
  owner               User       @relation("GymOwner", fields: [ownerId], references: [id])
  addons              GymAddon[]
  plans               Plan[]
  reviews             Review[]
}

model Review {
  id        String   @id @default(cuid())
  gymId     String
  userId    String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  gym       Gym      @relation(fields: [gymId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Plan {
  id        String    @id @default(cuid())
  gymId     String
  type      PlanType
  price     Float
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  bookings  Booking[]
  gym       Gym       @relation(fields: [gymId], references: [id])
}

model GymAddon {
  id          String   @id @default(cuid())
  gymId       String
  name        String
  price       Float
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  gym         Gym      @relation(fields: [gymId], references: [id])
}

model Booking {
  id             String        @id @default(cuid())
  userId         String
  gymId          String
  planId         String
  bookingDate    DateTime
  status         BookingStatus @default(BOOKED)
  paymentId      String?
  otp            String?
  qrCode         String?
  voucherPdfUrl  String?
  members        Json?
  selectedAddons Json?
  totalAmount    Float
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  paymentType    PaymentType   @default(ONLINE)
  gym            Gym           @relation(fields: [gymId], references: [id])
  plan           Plan          @relation(fields: [planId], references: [id])
  user           User          @relation(fields: [userId], references: [id])
}

model Transaction {
  id                String   @id @default(cuid())
  userId            String
  amount            Float
  status            String
  razorpayOrderId   String   @unique
  razorpayPaymentId String?  @unique
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id])
}

model SupportTicket {
  id        String         @id @default(cuid())
  ticketId  String         @unique
  userId    String
  subject   String
  message   String
  category  TicketCategory @default(DISPUTE)
  status    TicketStatus   @default(OPEN)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id])
}

enum TicketCategory {
  DISPUTE
  FEEDBACK
  TECHNICAL
  OTHER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum Role {
  USER
  GYM_OWNER
  ADMIN
}

enum GymStatus {
  PENDING
  APPROVED
  REJECTED
  AWAITING_PAYMENT
  SUSPENDED
}

enum PaymentType {
  ONLINE
  PAY_AT_GYM
}

enum PlanType {
  DAY
  WEEK
  MONTH
}

enum BookingStatus {
  BOOKED
  CHECKED_IN
  COMPLETED
  CANCELLED
}

model PlatformSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model BookingIntent {
  id             String       @id @default(cuid())
  userId         String
  gymId          String
  planId         String
  amount         Float
  members        Int          @default(1)
  selectedAddons Json?
  status         IntentStatus @default(PENDING)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id])
  gym            Gym          @relation(fields: [gymId], references: [id])

  @@index([userId])
  @@index([status])
}

enum IntentStatus {
  PENDING
  CONVERTED
  RECOVERED
  ABANDONED
}
